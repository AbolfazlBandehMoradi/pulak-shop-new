{
  "hero": {
    "title": "\u0628\u0647 \u0641\u0631\u0648\u0634\u06af\u0627\u0647 \u0645\u0627 \u062e\u0648\u0634 \u0622\u0645\u062f\u06cc\u062f",
    "shopName": "\u0628\u0647\u0634\u062a \u0632\u06cc\u0628\u0627\u06cc\u06cc \u067e\u0648\u0644\u06a9",
    "caption": "\u0634\u0631\u06a9\u062a \u06af\u0627\u0645\u0627 \u0637\u0628 \u0622\u0633\u06cc\u0627 \u0628\u0647 \u0639\u0646\u0648\u0627\u0646 \u06cc\u06a9\u06cc \u0627\u0632 \u062a\u0648\u0644\u06cc\u062f\u06a9\u0646\u0646\u062f\u06af\u0627\u0646 \u067e\u06cc\u0634\u0631\u0648 \u062f\u0631 \u062d\u0648\u0632\u0647 \u062a\u062c\u0647\u06cc\u0632\u0627\u062a \u067e\u0632\u0634\u06a9\u06cc\u060c \u0641\u0639\u0627\u0644\u06cc\u062a \u062e\u0648\u062f \u0631\u0627 \u0627\u0632 \u0633\u0627\u0644 \u06f1\u06f3\u06f8\u06f1 \u0622\u063a\u0627\u0632 \u06a9\u0631\u062f\u0647 \u0627\u0633\u062a. \u0627\u06cc\u0646 \u0634\u0631\u06a9\u062a \u0627\u0632 \u0633\u0627\u0644 \u06f1\u06f4\u06f0\u06f0 \u0628\u0627 \u0631\u0648\u06cc\u06a9\u0631\u062f\u06cc \u0646\u0648\u0622\u0648\u0631\u0627\u0646\u0647 \u0648 \u0628\u0627 \u062a\u0645\u0631\u06a9\u0632 \u0628\u0631 \u0645\u062d\u0635\u0648\u0644\u0627\u062a \u0628\u0647\u062f\u0627\u0634\u062a\u06cc \u0645\u0648\u0631\u062f \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u062f\u0631 \u0635\u0646\u0627\u06cc\u0639 \u063a\u0630\u0627\u06cc\u06cc \u0648 \u062f\u0627\u0631\u0648\u06cc\u06cc\u060c \u0628\u0631\u0627\u06cc \u0627\u0648\u0644\u06cc\u0646\u200c\u0628\u0627\u0631 \u0628\u0647 \u0635\u0648\u0631\u062a \u062a\u062e\u0635\u0635\u06cc \u0627\u0642\u062f\u0627\u0645 \u0628\u0647 \u062a\u0648\u0644\u06cc\u062f \u0627\u0633\u067e\u0631\u06cc \u062e\u0648\u0634\u0628\u0648\u06a9\u0646\u0646\u062f\u0647 \u062f\u0647\u0627\u0646 \u0646\u0645\u0648\u062f\u0647 \u0627\u0633\u062a",
    "shopNameTwo": "",
    "subtitle": "\u0628\u0647\u062a\u0631\u06cc\u0646 \u0645\u062d\u0635\u0648\u0644\u0627\u062a \u0628\u0627 \u0628\u0647\u062a\u0631\u06cc\u0646 \u0642\u06cc\u0645\u062a",
    "cta": "\u0645\u0634\u0627\u0647\u062f\u0647 \u0645\u062d\u0635\u0648\u0644\u0627\u062a",
