    "imageAlt": "\u0645\u062d\u0635\u0648\u0644\u0627\u062a \u0622\u0631\u0627\u06cc\u0634\u06cc \u0648 \u0628\u0647\u062f\u0627\u0634\u062a\u06cc \u067e\u0648\u0644\u06a9",
    "features": {
      "production": {
        "title": "\u062a\u0646\u0648\u0639 \u06a9\u0627\u0645\u0644 \u0645\u062d\u0635\u0648\u0644\u0627\u062a \u0632\u06cc\u0628\u0627\u06cc\u06cc",
        "description": "\u062f\u0631 \u067e\u0648\u0644\u06a9 \u062c\u062f\u06cc\u062f\u062a\u0631\u06cc\u0646 \u0645\u062d\u0635\u0648\u0644\u0627\u062a \u0622\u0631\u0627\u06cc\u0634\u06cc \u0648 \u0628\u0647\u062f\u0627\u0634\u062a\u06cc \u0627\u0632 \u0628\u0631\u0646\u062f\u0647\u0627\u06cc \u0645\u0639\u062a\u0628\u0631 \u062c\u0647\u0627\u0646\u06cc \u0631\u0627 \u06cc\u06a9\u062c\u0627 \u0645\u06cc\u200c\u0628\u06cc\u0646\u06cc\u062f \u0648 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u06cc\u062f \u0628\u0627 \u062e\u06cc\u0627\u0644 \u0631\u0627\u062d\u062a \u0627\u0646\u062a\u062e\u0627\u0628 \u06a9\u0646\u06cc\u062f."
      },
      "certification": {
        "title": "\u0627\u0635\u0627\u0644\u062a \u06a9\u0627\u0644\u0627 \u0648 \u06a9\u06cc\u0641\u06cc\u062a \u062a\u0636\u0645\u06cc\u0646\u200c\u0634\u062f\u0647",
        "description": "\u062a\u0645\u0627\u0645 \u0645\u062d\u0635\u0648\u0644\u0627\u062a \u0628\u0627 \u062f\u0642\u062a \u0627\u0646\u062a\u062e\u0627\u0628 \u0645\u06cc\u200c\u0634\u0648\u0646\u062f \u062a\u0627 \u062e\u0631\u06cc\u062f\u06cc \u0645\u0637\u0645\u0626\u0646 \u062f\u0627\u0634\u062a\u0647 \u0628\u0627\u0634\u06cc\u062f\u061b \u06a9\u06cc\u0641\u06cc\u062a \u0628\u0627\u0644\u0627 \u0648 \u0627\u0635\u0627\u0644\u062a \u06a9\u0627\u0644\u0627 \u0628\u0631\u0627\u06cc \u0645\u0627 \u0627\u0648\u0644\u0648\u06cc\u062a \u0627\u0635\u0644\u06cc \u0627\u0633\u062a."
      },
      "delivery": {
        "title": "\u0627\u0631\u0633\u0627\u0644 \u0633\u0631\u06cc\u0639 \u0648 \u0645\u0637\u0645\u0626\u0646",
        "description": "\u067e\u0633 \u0627\u0632 \u062b\u0628\u062a \u0633\u0641\u0627\u0631\u0634\u060c \u0628\u0633\u062a\u0647 \u0634\u0645\u0627 \u062f\u0631 \u0633\u0631\u06cc\u0639\u200c\u062a\u0631\u06cc\u0646 \u0632\u0645\u0627\u0646 \u0645\u0645\u06a9\u0646 \u0628\u0627 \u0628\u0633\u062a\u0647\u200c\u0628\u0646\u062f\u06cc \u0627\u0645\u0646 \u0627\u0631\u0633\u0627\u0644 \u0645\u06cc\u200c\u0634\u0648\u062f \u062a\u0627 \u0628\u062f\u0648\u0646 \u062f\u063a\u062f\u063a\u0647 \u0628\u0647 \u062f\u0633\u062a\u062a\u0627\u0646 \u0628\u0631\u0633\u062f."
      },
      "experience": {
        "title": "\u062a\u062e\u0641\u06cc\u0641\u200c\u0647\u0627\u06cc \u0648\u06cc\u0698\u0647 \u0648 \u0647\u0645\u0631\u0627\u0647\u06cc \u0648\u0627\u0642\u0639\u06cc",
        "description": "\u0628\u0627 \u067e\u06cc\u0634\u0646\u0647\u0627\u062f\u0647\u0627\u06cc \u0648\u06cc\u0698\u0647\u060c \u0642\u06cc\u0645\u062a\u200c\u0647\u0627\u06cc \u0645\u0646\u0627\u0633\u0628 \u0648 \u067e\u0634\u062a\u06cc\u0628\u0627\u0646\u06cc \u067e\u0627\u0633\u062e\u200c\u06af\u0648\u060c \u062a\u062c\u0631\u0628\u0647 \u062e\u0631\u06cc\u062f \u0622\u0646\u0644\u0627\u06cc\u0646 \u0645\u062d\u0635\u0648\u0644\u0627\u062a \u0632\u06cc\u0628\u0627\u06cc\u06cc \u0628\u0631\u0627\u06cc \u0634\u0645\u0627 \u0631\u0627\u062d\u062a\u200c\u062a\u0631 \u0648 \u0644\u0630\u062a\u200c\u0628\u062e\u0634\u200c\u062a\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f."
      }
    }
  },
